# ==============================================================
# | TTFB-Optimized .htaccess for aiprofitlab.io                |
# | Goal: Reduce server processing time per request             |
# ==============================================================

# --- Compression (mod_deflate) ---
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css
    AddOutputFilterByType DEFLATE text/javascript application/javascript application/x-javascript
    AddOutputFilterByType DEFLATE application/xml application/xhtml+xml application/rss+xml
    AddOutputFilterByType DEFLATE application/json application/ld+json
    AddOutputFilterByType DEFLATE image/svg+xml image/x-icon
    AddOutputFilterByType DEFLATE font/opentype font/otf font/ttf
    AddOutputFilterByType DEFLATE application/vnd.ms-fontobject application/x-font-ttf application/x-font-opentype
</IfModule>

# --- Expires Headers (mod_expires) ---
<IfModule mod_expires.c>
    ExpiresActive On
    # HTML: short cache so content updates propagate quickly
    ExpiresByType text/html "access plus 10 minutes"
    # Static assets: aggressive 1-year cache
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/svg+xml "access plus 1 year"
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType text/javascript "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType font/ttf "access plus 1 year"
    ExpiresByType font/woff "access plus 1 year"
    ExpiresByType font/woff2 "access plus 1 year"
    ExpiresByType application/font-woff2 "access plus 1 year"
</IfModule>

# --- Cache-Control Headers (mod_headers) ---
<IfModule mod_headers.c>
    # Immutable static assets (1 year)
    <FilesMatch "\.(jpeg|jpg|png|webp|svg|ico|css|js|woff|woff2|ttf|otf|eot)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
    # HTML pages: short cache with revalidation
    <FilesMatch "\.html$">
        Header set Cache-Control "public, max-age=600, must-revalidate"
    </FilesMatch>
    # Remove ETag to avoid conditional-GET overhead on shared hosting
    Header unset ETag
</IfModule>
FileETag None

# --- Basic Server Configuration ---
Options +FollowSymLinks -MultiViews -Indexes
DirectoryIndex index.html

# Allow access
<Files "*">
    Require all granted
</Files>

# --- URL Rewriting ---
RewriteEngine On
RewriteBase /

# 1. Force trailing slash on ALL URLs (except real files)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_URI} !(.*)/$
RewriteRule ^(.*)$ https://aiprofitlab.io/$1/ [L,R=301]

# 2. Specific Hub Redirects (PRIORITY)
RewriteRule ^en/blog/$ blog/index.html [L]
RewriteRule ^en/academy/$ academy/index.html [L]

# 3. Map /en/ subpaths to root -en.html files
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^en/([^/]+)/$ $1.html [L]

# 4. Map Clean URLs for Blog and Academy subdirectories
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(blog|academy)/(en|ar)/([^/]+)/$ $1/$2/$3.html [L]

# 5. Map clean directory URLs to root .html files (Arabic/General)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^([^/]+)/$ $1.html [L]

# 6. Legacy Redirects (Cleanup)
RewriteRule ^Missed-Call-Simulator-en/?$ /en/missed-call-simulator-en/ [R=301,L]
RewriteRule ^Campaign_ROI_Simulator-ar/?$ /campaign-roi-simulator-ar/ [R=301,L]
RewriteRule ^academy_ar/?$ /academy-ar/ [R=301,L]
RewriteRule ^Campaign_ROI_Simulator/?$ /campaign-roi-simulator/ [R=301,L]
RewriteRule ^whatsapp_receptionist_demo/?$ /whatsapp-receptionist-demo/ [R=301,L]
RewriteRule ^Missed-Call-Simulator-ar/?$ /missed-call-simulator-ar/ [R=301,L]
RewriteRule ^Customized_CEO_Dashboard_demo/?$ /customized-ceo-dashboard-demo/ [R=301,L]
RewriteRule ^blog_ar/?$ /blog-ar/ [R=301,L]
RewriteRule ^Customized_CEO_Dashboard_demo-ar/?$ /customized-ceo-dashboard-demo-ar/ [R=301,L]
RewriteRule ^whatsapp_receptionist_demo_ar/?$ /whatsapp-receptionist-demo-ar/ [R=301,L]

# 7. Redirect .html URLs to clean slash versions
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /(.+)\.html\ HTTP/
RewriteRule ^(.+)\.html$ https://aiprofitlab.io/$1/ [R=301,L]

# 8. Special case for index.html files
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /en/index\.html\ HTTP/
RewriteRule ^en/index\.html$ https://aiprofitlab.io/en/ [R=301,L]

RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /index\.html\ HTTP/
RewriteRule ^index\.html$ https://aiprofitlab.io/ [R=301,L]
