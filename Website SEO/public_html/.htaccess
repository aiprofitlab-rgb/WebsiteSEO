# Basic Server Configuration
Options +FollowSymLinks
Options -MultiViews
Options -Indexes
DirectoryIndex index.html

# Allow access
<Files "*">
    Require all granted
</Files>

# Enable Rewriting
RewriteEngine On
RewriteBase /

# 1. Force trailing slash on ALL URLs (except files)
# If it's not a file and doesn't end in a slash, redirect to slash version
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_URI} !(.*)/$
RewriteRule ^(.*)$ https://aiprofitlab.io/$1/ [L,R=301]

# 2. Map clean directory URLs to .html files
# Example: /services/ -> services.html
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^([^/]+)/$ $1.html [L]

# 3. Specific Subdirectory Mapping (Academy, Blog, etc.)
# These already have index.html inside them, so Apache serves them for /academy/
# But we should ensure we don't break them
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^(.*)$ - [L]

# 4. Standardized URL Slug Redirects (Legacy to New Slugs)
RewriteRule ^Missed-Call-Simulator-en/?$ /missed-call-simulator-en/ [R=301,L]
RewriteRule ^Campaign_ROI_Simulator-ar/?$ /campaign-roi-simulator-ar/ [R=301,L]
RewriteRule ^academy_ar/?$ /academy-ar/ [R=301,L]
RewriteRule ^Campaign_ROI_Simulator/?$ /campaign-roi-simulator/ [R=301,L]
RewriteRule ^whatsapp_receptionist_demo/?$ /whatsapp-receptionist-demo/ [R=301,L]
RewriteRule ^Missed-Call-Simulator-ar/?$ /missed-call-simulator-ar/ [R=301,L]
RewriteRule ^Customized_CEO_Dashboard_demo/?$ /customized-ceo-dashboard-demo/ [R=301,L]
RewriteRule ^blog_ar/?$ /blog-ar/ [R=301,L]
RewriteRule ^Customized_CEO_Dashboard_demo-ar/?$ /customized-ceo-dashboard-demo-ar/ [R=301,L]
RewriteRule ^whatsapp_receptionist_demo_ar/?$ /whatsapp-receptionist-demo-ar/ [R=301,L]

# 5. Redirect .html URLs to clean slash versions
# Example: /services.html -> /services/
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /(.+)\.html\ HTTP/
RewriteRule ^(.+)\.html$ https://aiprofitlab.io/$1/ [R=301,L]

# Special case for index.html at root
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /index\.html\ HTTP/
RewriteRule ^index\.html$ https://aiprofitlab.io/ [R=301,L]
